{
  "name": "skillpkg-studio",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "productName": "Skillpkg Studio",
  "dependencies": {
    "@fluentui/react-icons": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "5.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "craco start",
    "build": "craco build",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.cjs --mac",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.cjs --win",
    "dist:linux": "npm run build && electron-builder --config electron-builder.config.cjs --linux",
    "test": "craco test",
    "eject": "react-scripts eject",
    "elec": "electron .",
    "dev": "concurrently -k \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && electron .\""
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "22.22.2"
  },
  "volta": {
    "node": "22.22.2"
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.5.12",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^4.9.5",
    "wait-on": "^8.0.5"
  }
}
